    "https-proxy-agent": "^9.0.0",
    "lucide-react": "^1.8.0",
    "matter-js": "^0.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "undici": "^7.24.8",
    "ws": "^8.18.3",
    "zod": "^4.1.12",
    "zustand": "^5.0.12"
