{
  "name": "polymarket-weather-monitor",
  "productName": "Polymarket Weather Monitor",
  "version": "0.1.0",
  "description": "Windows desktop monitor for Polymarket weather markets.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "dev": "electron-forge start",
    "start": "electron-forge start",
    "clean:generated": "node scripts/clean-generated-artifacts.mjs",
    "prepackage": "node scripts/prepare-runtime-deps.mjs",
    "package": "electron-forge package",
    "premake": "node scripts/prepare-runtime-deps.mjs",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx src tests forge.config.ts vite.*.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild:sqlite": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [
    "electron",
    "polymarket",
    "weather",
    "monitor"
  ],
  "author": {
    "name": "yyx",
    "email": "3236064212@qq.com"
  },
  "license": "MIT",
